{
  "name": "kicad-viewer",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "bun run dev",
    "dev": "vite",
    "build": "tsc && vite build",
    "vercel-build": "bun run build",
    "lint": "biome lint",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "preview": "vite preview",
    "update-deps": "bun add @tscircuit/builder@latest @tscircuit/pcb-viewer@latest kicad-mod-converter@latest",
    "aider": "aider --no-auto-commits --no-auto-lint"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@tscircuit/alphabet": "^0.0.22",
    "@tscircuit/pcb-viewer": "^1.11.353",
    "kicad-mod-converter": "^0.0.30",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.12.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tscircuit": "^0.0.1525",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  }
}
